{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "jsxImportSource": "react",
    "noImplicitAny": false,
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@components/*": ["src/components/*"],
      "@src/*": ["src/*"]
    }
  }
}